{
  "meta": {
    "name": "default-dark",
    "version": "1.0.0",
    "mode": "dark",
    "vibeTags": ["professional", "minimal"],
    "description": "默认暗色主题：与 default-light 共享色阶，仅调整中性色映射；适合开发者工具/夜间模式"
  },
  "color": {
    "primary": {
      "50":  "#172554",
      "100": "#1e3a8a",
      "200": "#1e40af",
      "300": "#1d4ed8",
      "400": "#2563eb",
      "500": "#3b82f6",
      "600": "#60a5fa",
      "700": "#93c5fd",
      "800": "#bfdbfe",
      "900": "#dbeafe"
    },
    "neutral": {
      "50":  "#0a0a0a",
      "100": "#171717",
      "200": "#262626",
      "300": "#404040",
      "400": "#525252",
      "500": "#737373",
      "600": "#a3a3a3",
      "700": "#d4d4d4",
      "800": "#e5e5e5",
      "900": "#fafafa"
    },
    "semantic": {
      "success": { "50": "#052e16", "100": "#14532d", "200": "#166534", "300": "#15803d", "400": "#16a34a", "500": "#22c55e", "600": "#4ade80", "700": "#86efac", "800": "#bbf7d0", "900": "#dcfce7" },
      "warning": { "50": "#451a03", "100": "#78350f", "200": "#92400e", "300": "#b45309", "400": "#d97706", "500": "#f59e0b", "600": "#fbbf24", "700": "#fcd34d", "800": "#fde68a", "900": "#fef3c7" },
      "danger":  { "50": "#450a0a", "100": "#7f1d1d", "200": "#991b1b", "300": "#b91c1c", "400": "#dc2626", "500": "#ef4444", "600": "#f87171", "700": "#fca5a5", "800": "#fecaca", "900": "#fee2e2" },
      "info":    { "50": "#172554", "100": "#1e3a8a", "200": "#1e40af", "300": "#1d4ed8", "400": "#2563eb", "500": "#3b82f6", "600": "#60a5fa", "700": "#93c5fd", "800": "#bfdbfe", "900": "#dbeafe" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", system-ui, sans-serif",
      "serif": "Georgia, \"Times New Roman\", serif",
      "mono": "\"JetBrains Mono\", \"Fira Code\", Menlo, Consolas, monospace"
    },
    "fontSize": { "xs": 12, "sm": 14, "base": 16, "lg": 18, "xl": 20, "2xl": 24, "3xl": 30, "4xl": 36, "5xl": 48 },
    "lineHeight": { "tight": 1.25, "normal": 1.5, "relaxed": 1.75 },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "spacing": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "6": 24, "8": 32, "12": 48, "16": 64, "24": 96 },
  "radius":  { "none": 0, "sm": 4, "md": 8, "lg": 12, "xl": 16, "full": 9999 },
  "shadow": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0,0,0,.4)",
    "md": "0 4px 8px -2px rgba(0,0,0,.5), 0 2px 4px -2px rgba(0,0,0,.3)",
    "lg": "0 12px 24px -8px rgba(0,0,0,.6), 0 4px 8px -4px rgba(0,0,0,.35)",
    "xl": "0 24px 48px -12px rgba(0,0,0,.7)"
  },
  "breakpoint": {
    "mobile": 0,
    "tablet": 768,
    "desktop": 1024,
    "wide": 1440,
    "scaling": {
      "fontSize": {
        "base": { "min": 14, "max": 16 },
        "lg":   { "min": 16, "max": 18 },
        "xl":   { "min": 18, "max": 20 },
        "2xl":  { "min": 20, "max": 24 },
        "3xl":  { "min": 24, "max": 30 },
        "4xl":  { "min": 30, "max": 36 },
        "5xl":  { "min": 36, "max": 48 }
      },
      "spacing":   { "mobile": 0.875, "tablet": 1.0, "desktop": 1.0, "wide": 1.125 },
      "container": { "mobile": 0,     "tablet": 720, "desktop": 960, "wide": 1280 }
    }
  },
  "motion": {
    "duration": { "instant": 0, "fast": 150, "base": 220, "slow": 320 },
    "easing": {
      "standard":   "cubic-bezier(.2,0,0,1)",
      "emphasized": "cubic-bezier(.3,0,0,1)",
      "decelerate": "cubic-bezier(0,0,.2,1)",
      "accelerate": "cubic-bezier(.4,0,1,1)"
    }
  },
  "zIndex": { "base": 0, "dropdown": 1000, "sticky": 1100, "modal": 1300, "popover": 1400, "toast": 1500 },
  "icon": { "source": "lucide", "sizeBase": 20, "strokeWidth": 1.75 }
}
