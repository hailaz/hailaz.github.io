{
  "meta": {
    "name": "minimal",
    "version": "1.0.0",
    "mode": "light",
    "vibeTags": ["minimal", "calm", "professional"],
    "description": "极简单色：去除色彩干扰，仅以中性灰阶 + 黑白主色构图，强调留白与排版"
  },
  "color": {
    "primary": {
      "50":  "#fafafa",
      "100": "#f4f4f4",
      "200": "#e4e4e4",
      "300": "#d1d1d1",
      "400": "#a3a3a3",
      "500": "#171717",
      "600": "#0a0a0a",
      "700": "#050505",
      "800": "#000000",
      "900": "#000000"
    },
    "neutral": {
      "50":  "#fafafa",
      "100": "#f4f4f4",
      "200": "#e4e4e4",
      "300": "#d1d1d1",
      "400": "#a3a3a3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "semantic": {
      "success": { "50": "#f4f4f4", "100": "#e4e4e4", "200": "#d1d1d1", "300": "#a3a3a3", "400": "#737373", "500": "#22c55e", "600": "#525252", "700": "#404040", "800": "#262626", "900": "#171717" },
      "warning": { "50": "#f4f4f4", "100": "#e4e4e4", "200": "#d1d1d1", "300": "#a3a3a3", "400": "#737373", "500": "#f59e0b", "600": "#525252", "700": "#404040", "800": "#262626", "900": "#171717" },
      "danger":  { "50": "#f4f4f4", "100": "#e4e4e4", "200": "#d1d1d1", "300": "#a3a3a3", "400": "#737373", "500": "#ef4444", "600": "#525252", "700": "#404040", "800": "#262626", "900": "#171717" },
      "info":    { "50": "#f4f4f4", "100": "#e4e4e4", "200": "#d1d1d1", "300": "#a3a3a3", "400": "#737373", "500": "#171717", "600": "#525252", "700": "#404040", "800": "#262626", "900": "#171717" }
    },
    "modeOverrides": {
      "dark": {
        "neutral": {
          "50":  "#0a0a0a", "100": "#171717", "200": "#262626", "300": "#404040",
          "400": "#525252", "500": "#737373", "600": "#a3a3a3", "700": "#d1d1d1",
          "800": "#e4e4e4", "900": "#fafafa"
        },
        "primary": {
          "50":  "#0a0a0a", "100": "#171717", "200": "#262626", "300": "#404040",
          "400": "#737373", "500": "#fafafa", "600": "#ffffff", "700": "#ffffff",
          "800": "#ffffff", "900": "#ffffff"
        }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "\"Inter\", \"Helvetica Neue\", \"PingFang SC\", system-ui, sans-serif",
      "serif": "\"EB Garamond\", Georgia, serif",
      "mono": "\"IBM Plex Mono\", monospace"
    },
    "fontSize": { "xs": 12, "sm": 14, "base": 16, "lg": 18, "xl": 20, "2xl": 24, "3xl": 30, "4xl": 36, "5xl": 48 },
    "lineHeight": { "tight": 1.3, "normal": 1.6, "relaxed": 1.85 },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "spacing": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "6": 24, "8": 32, "12": 48, "16": 64, "24": 96 },
  "radius":  { "none": 0, "sm": 2, "md": 4, "lg": 6, "xl": 8, "full": 9999 },
  "shadow": {
    "none": "none",
    "sm": "0 0 0 1px rgba(0,0,0,.04)",
    "md": "0 0 0 1px rgba(0,0,0,.06)",
    "lg": "0 0 0 1px rgba(0,0,0,.08)",
    "xl": "0 0 0 1px rgba(0,0,0,.12)"
  },
  "breakpoint": {
    "mobile": 0, "tablet": 768, "desktop": 1024, "wide": 1440,
    "scaling": {
      "fontSize": {
        "base": { "min": 14, "max": 16 },
        "lg":   { "min": 16, "max": 18 },
        "xl":   { "min": 18, "max": 20 },
        "2xl":  { "min": 20, "max": 24 },
        "3xl":  { "min": 24, "max": 30 },
        "4xl":  { "min": 30, "max": 36 },
        "5xl":  { "min": 36, "max": 48 }
      },
      "spacing":   { "mobile": 1.0, "tablet": 1.0, "desktop": 1.125, "wide": 1.25 },
      "container": { "mobile": 0,   "tablet": 680, "desktop": 880,   "wide": 1080 }
    }
  },
  "motion": {
    "duration": { "instant": 0, "fast": 120, "base": 200, "slow": 280 },
    "easing": {
      "standard":   "cubic-bezier(.2,0,0,1)",
      "emphasized": "cubic-bezier(.3,0,0,1)",
      "decelerate": "cubic-bezier(0,0,.2,1)",
      "accelerate": "cubic-bezier(.4,0,1,1)"
    }
  },
  "zIndex": { "base": 0, "dropdown": 1000, "sticky": 1100, "modal": 1300, "popover": 1400, "toast": 1500 },
  "icon": { "source": "lucide", "sizeBase": 18, "strokeWidth": 1.25 }
}
