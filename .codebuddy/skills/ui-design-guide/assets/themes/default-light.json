{
  "meta": {
    "name": "default-light",
    "version": "1.0.0",
    "mode": "light",
    "vibeTags": ["professional", "minimal"],
    "description": "默认亮色主题：中性蓝主色 + 标准 spacing 阶梯，适合 SaaS / 工具类产品起步"
  },
  "color": {
    "primary": {
      "50":  "#eff6ff",
      "100": "#dbeafe",
      "200": "#bfdbfe",
      "300": "#93c5fd",
      "400": "#60a5fa",
      "500": "#3b82f6",
      "600": "#2563eb",
      "700": "#1d4ed8",
      "800": "#1e40af",
      "900": "#1e3a8a"
    },
    "neutral": {
      "50":  "#fafafa",
      "100": "#f5f5f5",
      "200": "#e5e5e5",
      "300": "#d4d4d4",
      "400": "#a3a3a3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "semantic": {
      "success": { "50": "#f0fdf4", "100": "#dcfce7", "200": "#bbf7d0", "300": "#86efac", "400": "#4ade80", "500": "#22c55e", "600": "#16a34a", "700": "#15803d", "800": "#166534", "900": "#14532d" },
      "warning": { "50": "#fffbeb", "100": "#fef3c7", "200": "#fde68a", "300": "#fcd34d", "400": "#fbbf24", "500": "#f59e0b", "600": "#d97706", "700": "#b45309", "800": "#92400e", "900": "#78350f" },
      "danger":  { "50": "#fef2f2", "100": "#fee2e2", "200": "#fecaca", "300": "#fca5a5", "400": "#f87171", "500": "#ef4444", "600": "#dc2626", "700": "#b91c1c", "800": "#991b1b", "900": "#7f1d1d" },
      "info":    { "50": "#eff6ff", "100": "#dbeafe", "200": "#bfdbfe", "300": "#93c5fd", "400": "#60a5fa", "500": "#3b82f6", "600": "#2563eb", "700": "#1d4ed8", "800": "#1e40af", "900": "#1e3a8a" }
    },
    "modeOverrides": {
      "dark": {
        "neutral": {
          "50":  "#171717",
          "100": "#262626",
          "200": "#404040",
          "300": "#525252",
          "400": "#737373",
          "500": "#a3a3a3",
          "600": "#d4d4d4",
          "700": "#e5e5e5",
          "800": "#f5f5f5",
          "900": "#fafafa"
        }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", system-ui, sans-serif",
      "serif": "Georgia, \"Times New Roman\", serif",
      "mono": "\"JetBrains Mono\", \"Fira Code\", Menlo, Consolas, monospace"
    },
    "fontSize": { "xs": 12, "sm": 14, "base": 16, "lg": 18, "xl": 20, "2xl": 24, "3xl": 30, "4xl": 36, "5xl": 48 },
    "lineHeight": { "tight": 1.25, "normal": 1.5, "relaxed": 1.75 },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "spacing": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "6": 24, "8": 32, "12": 48, "16": 64, "24": 96 },
  "radius":  { "none": 0, "sm": 4, "md": 8, "lg": 12, "xl": 16, "full": 9999 },
  "shadow": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0,0,0,.06)",
    "md": "0 4px 8px -2px rgba(0,0,0,.08), 0 2px 4px -2px rgba(0,0,0,.04)",
    "lg": "0 12px 24px -8px rgba(0,0,0,.12), 0 4px 8px -4px rgba(0,0,0,.06)",
    "xl": "0 24px 48px -12px rgba(0,0,0,.18)"
  },
  "breakpoint": {
    "mobile": 0,
    "tablet": 768,
    "desktop": 1024,
    "wide": 1440,
    "scaling": {
      "fontSize": {
        "base": { "min": 14, "max": 16 },
        "lg":   { "min": 16, "max": 18 },
        "xl":   { "min": 18, "max": 20 },
        "2xl":  { "min": 20, "max": 24 },
        "3xl":  { "min": 24, "max": 30 },
        "4xl":  { "min": 30, "max": 36 },
        "5xl":  { "min": 36, "max": 48 }
      },
      "spacing":   { "mobile": 0.875, "tablet": 1.0, "desktop": 1.0, "wide": 1.125 },
      "container": { "mobile": 0,     "tablet": 720, "desktop": 960, "wide": 1280 }
    }
  },
  "motion": {
    "duration": { "instant": 0, "fast": 150, "base": 220, "slow": 320 },
    "easing": {
      "standard":   "cubic-bezier(.2,0,0,1)",
      "emphasized": "cubic-bezier(.3,0,0,1)",
      "decelerate": "cubic-bezier(0,0,.2,1)",
      "accelerate": "cubic-bezier(.4,0,1,1)"
    }
  },
  "zIndex": { "base": 0, "dropdown": 1000, "sticky": 1100, "modal": 1300, "popover": 1400, "toast": 1500 },
  "icon": { "source": "lucide", "sizeBase": 20, "strokeWidth": 1.75 }
}
