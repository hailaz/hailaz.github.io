{
  "meta": {
    "name": "material-style",
    "version": "1.0.0",
    "mode": "light",
    "vibeTags": ["energetic", "professional"],
    "description": "Material Design 风：高对比饱和主色 + 阴影分层 + Roboto 字阶，强调结构与层级"
  },
  "color": {
    "primary": {
      "50":  "#e3f2fd",
      "100": "#bbdefb",
      "200": "#90caf9",
      "300": "#64b5f6",
      "400": "#42a5f5",
      "500": "#2196f3",
      "600": "#1e88e5",
      "700": "#1976d2",
      "800": "#1565c0",
      "900": "#0d47a1"
    },
    "neutral": {
      "50":  "#fafafa",
      "100": "#f5f5f5",
      "200": "#eeeeee",
      "300": "#e0e0e0",
      "400": "#bdbdbd",
      "500": "#9e9e9e",
      "600": "#757575",
      "700": "#616161",
      "800": "#424242",
      "900": "#212121"
    },
    "semantic": {
      "success": { "50": "#e8f5e9", "100": "#c8e6c9", "200": "#a5d6a7", "300": "#81c784", "400": "#66bb6a", "500": "#4caf50", "600": "#43a047", "700": "#388e3c", "800": "#2e7d32", "900": "#1b5e20" },
      "warning": { "50": "#fff8e1", "100": "#ffecb3", "200": "#ffe082", "300": "#ffd54f", "400": "#ffca28", "500": "#ffc107", "600": "#ffb300", "700": "#ffa000", "800": "#ff8f00", "900": "#ff6f00" },
      "danger":  { "50": "#ffebee", "100": "#ffcdd2", "200": "#ef9a9a", "300": "#e57373", "400": "#ef5350", "500": "#f44336", "600": "#e53935", "700": "#d32f2f", "800": "#c62828", "900": "#b71c1c" },
      "info":    { "50": "#e1f5fe", "100": "#b3e5fc", "200": "#81d4fa", "300": "#4fc3f7", "400": "#29b6f6", "500": "#03a9f4", "600": "#039be5", "700": "#0288d1", "800": "#0277bd", "900": "#01579b" }
    },
    "modeOverrides": {
      "dark": {
        "neutral": {
          "50":  "#121212",
          "100": "#1e1e1e",
          "200": "#2c2c2c",
          "300": "#383838",
          "400": "#5e5e5e",
          "500": "#8a8a8a",
          "600": "#a8a8a8",
          "700": "#c2c2c2",
          "800": "#e0e0e0",
          "900": "#fafafa"
        }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Roboto, \"Noto Sans SC\", system-ui, sans-serif",
      "serif": "\"Roboto Slab\", serif",
      "mono": "\"Roboto Mono\", monospace"
    },
    "fontSize": { "xs": 12, "sm": 14, "base": 16, "lg": 18, "xl": 20, "2xl": 24, "3xl": 32, "4xl": 40, "5xl": 56 },
    "lineHeight": { "tight": 1.2, "normal": 1.5, "relaxed": 1.75 },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },
  "spacing": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "6": 24, "8": 32, "12": 48, "16": 64, "24": 96 },
  "radius":  { "none": 0, "sm": 4, "md": 8, "lg": 16, "xl": 28, "full": 9999 },
  "shadow": {
    "none": "none",
    "sm": "0 1px 3px rgba(0,0,0,.12), 0 1px 2px rgba(0,0,0,.24)",
    "md": "0 3px 6px rgba(0,0,0,.16), 0 3px 6px rgba(0,0,0,.23)",
    "lg": "0 10px 20px rgba(0,0,0,.19), 0 6px 6px rgba(0,0,0,.23)",
    "xl": "0 14px 28px rgba(0,0,0,.25), 0 10px 10px rgba(0,0,0,.22)"
  },
  "breakpoint": {
    "mobile": 0, "tablet": 768, "desktop": 1024, "wide": 1440,
    "scaling": {
      "fontSize": {
        "base": { "min": 14, "max": 16 },
        "lg":   { "min": 16, "max": 18 },
        "xl":   { "min": 18, "max": 20 },
        "2xl":  { "min": 20, "max": 24 },
        "3xl":  { "min": 24, "max": 32 },
        "4xl":  { "min": 32, "max": 40 },
        "5xl":  { "min": 40, "max": 56 }
      },
      "spacing":   { "mobile": 0.875, "tablet": 1.0, "desktop": 1.0, "wide": 1.125 },
      "container": { "mobile": 0,     "tablet": 720, "desktop": 960, "wide": 1280 }
    }
  },
  "motion": {
    "duration": { "instant": 0, "fast": 150, "base": 250, "slow": 400 },
    "easing": {
      "standard":   "cubic-bezier(.4,0,.2,1)",
      "emphasized": "cubic-bezier(.4,0,0,1)",
      "decelerate": "cubic-bezier(0,0,.2,1)",
      "accelerate": "cubic-bezier(.4,0,1,1)"
    }
  },
  "zIndex": { "base": 0, "dropdown": 1000, "sticky": 1100, "modal": 1300, "popover": 1400, "toast": 1500 },
  "icon": { "source": "material-symbols", "sizeBase": 24, "strokeWidth": 2 }
}
