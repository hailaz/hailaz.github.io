/* uni.scss.example
 * --------------------------------------------------------
 * 复制为项目根 uni.scss，所有 vue 组件可直接使用 SCSS 变量。
 * 同时通过 page 选择器声明 CSS Variables，运行时可动态覆盖（暗黑模式）。
 */

/* ============ SCSS 变量（编译时） ============ */

$color-primary-50:  #eff6ff;
$color-primary-500: #3b82f6;
$color-primary-600: #2563eb;

$color-neutral-50:  #fafafa;
$color-neutral-100: #f5f5f5;
$color-neutral-500: #737373;
$color-neutral-900: #171717;

$color-success-500: #22c55e;
$color-warning-500: #f59e0b;
$color-danger-500:  #ef4444;
$color-info-500:    #3b82f6;

$font-size-base: 32rpx;
$font-size-lg:   36rpx;
$font-size-xl:   40rpx;

$space-1: 8rpx;
$space-2: 16rpx;
$space-3: 24rpx;
$space-4: 32rpx;
$space-6: 48rpx;

$radius-md: 16rpx;
$radius-lg: 24rpx;

$shadow-md: 0 8rpx 16rpx -4rpx rgba(0,0,0,.08);

$dur-base: 220ms;
$ease-standard: cubic-bezier(.2,0,0,1);

/* ============ CSS Variables（运行时） ============
 * 用 page 选择器，对小程序/H5/APP 都生效
 */
page {
  --color-primary-500: #{$color-primary-500};
  --color-primary-600: #{$color-primary-600};
  --color-neutral-50:  #{$color-neutral-50};
  --color-neutral-900: #{$color-neutral-900};
  --color-success-500: #{$color-success-500};
  --color-warning-500: #{$color-warning-500};
  --color-danger-500:  #{$color-danger-500};
  --color-info-500:    #{$color-info-500};

  --font-size-base: #{$font-size-base};
  --font-size-lg:   #{$font-size-lg};

  --space-1: #{$space-1};
  --space-2: #{$space-2};
  --space-3: #{$space-3};
  --space-4: #{$space-4};
  --space-6: #{$space-6};

  --radius-md: #{$radius-md};
  --radius-lg: #{$radius-lg};

  --shadow-md: #{$shadow-md};

  --dur-base: #{$dur-base};
  --ease-standard: #{$ease-standard};
}

/* 暗黑模式覆盖（需在 App.vue / uni.onThemeChange 中触发） */
.theme-dark {
  --color-neutral-50:  #171717;
  --color-neutral-900: #fafafa;
}

/* ============ 业务样式示例 ============ */

.btn-primary {
  background: var(--color-primary-500);
  color: #fff;
  padding: $space-3 $space-6;
  border-radius: $radius-md;
  font-size: $font-size-base;
  transition: background $dur-base $ease-standard;
  min-height: 88rpx;

  &:active { background: var(--color-primary-600); }
}

.card {
  background: var(--color-neutral-50);
  padding: $space-4;
  border-radius: $radius-lg;
  box-shadow: var(--shadow-md);

  // #ifdef MP-WEIXIN || MP-ALIPAY
  // 小程序专属（如需要时）
  // #endif

  // #ifdef H5 || APP-PLUS
  // 媒体查询仅 H5/APP 可用
  @media (min-width: 768px) {
    padding: $space-6;
  }
  // #endif
}
