/* ============================================================
 * app.wxss — 微信小程序全局样式（WeUI 规范 + ui-design-guide tokens）
 * 由 ui-design-guide/configurator 导出的 weui-light.json + 本文件共同组成
 * 使用方式：将本文件内容复制到小程序项目的 app.wxss 顶部
 * ============================================================ */

page {
  /* ========== 颜色 · 主色 ========== */
  --color-primary-50:  #edfcf3;
  --color-primary-100: #d4f7e1;
  --color-primary-200: #a8efc3;
  --color-primary-300: #71e2a0;
  --color-primary-400: #38cf78;
  --color-primary-500: #07c160;
  --color-primary-600: #06ad56;
  --color-primary-700: #059a4c;
  --color-primary-800: #047a3c;
  --color-primary-900: #035a2c;

  /* ========== 颜色 · 中性 ========== */
  --color-neutral-50:  #fafafa;
  --color-neutral-100: #f7f7f7;
  --color-neutral-200: #ededed;
  --color-neutral-300: #d6d6d6;
  --color-neutral-500: #888888;
  --color-neutral-700: #3d3d3d;
  --color-neutral-900: #111111;

  /* ========== 颜色 · 语义 ========== */
  --color-success-500: #07c160;
  --color-warning-500: #ffc300;
  --color-danger-500:  #fa5151;
  --color-info-500:    #10aeff;

  /* ========== WeUI 专属色（覆盖语义） ========== */
  --weui-brand:       #07c160;
  --weui-brand-dark:  #06ad56;
  --weui-link:        #576b95;
  --weui-red:         #fa5151;
  --weui-orange:      #fa9d3b;
  --weui-yellow:      #ffc300;
  --weui-green:       #91d300;
  --weui-lightgreen:  #95ec69;
  --weui-blue:        #10aeff;
  --weui-indigo:      #1485ee;
  --weui-purple:      #6467f0;
  --weui-bg-0:        #ededed;
  --weui-bg-1:        #f7f7f7;
  --weui-bg-2:        #ffffff;
  --weui-fg-0:        #000000;
  --weui-fg-1:        rgba(0,0,0,.55);
  --weui-fg-2:        rgba(0,0,0,.3);
  --weui-separator:   rgba(0,0,0,.1);

  /* ========== 间距（rpx，基于 4px 基线 × 2） ========== */
  --space-0:  0;
  --space-1:  8rpx;
  --space-2:  16rpx;
  --space-3:  24rpx;
  --space-4:  32rpx;
  --space-6:  48rpx;
  --space-8:  64rpx;
  --space-12: 96rpx;

  /* ========== 圆角 ========== */
  --radius-none: 0;
  --radius-sm:   8rpx;
  --radius-md:   16rpx;
  --radius-lg:   24rpx;
  --radius-xl:   32rpx;
  --radius-full: 9999rpx;

  /* ========== 阴影（小程序兼容性，不要过度使用） ========== */
  --shadow-none: none;
  --shadow-sm: 0 2rpx 4rpx rgba(0,0,0,.04);
  --shadow-md: 0 4rpx 16rpx -4rpx rgba(0,0,0,.08);
  --shadow-lg: 0 16rpx 40rpx -8rpx rgba(0,0,0,.12);

  /* ========== 字号（rpx） ========== */
  --font-size-xs:   22rpx;  /* 11px */
  --font-size-sm:   26rpx;  /* 13px */
  --font-size-base: 30rpx;  /* 15px */
  --font-size-lg:   34rpx;  /* 17px */
  --font-size-xl:   40rpx;  /* 20px */
  --font-size-2xl:  48rpx;  /* 24px */
  --font-size-3xl:  60rpx;  /* 30px */

  /* ========== 字重 ========== */
  --weight-regular:  400;
  --weight-medium:   500;
  --weight-semibold: 600;
  --weight-bold:     700;

  /* ========== 行高 ========== */
  --leading-tight:   1.25;
  --leading-normal:  1.5;
  --leading-relaxed: 1.75;

  /* ========== 动效（小程序支持 transition / animation） ========== */
  --dur-fast: 150ms;
  --dur-base: 250ms;
  --dur-slow: 350ms;
  --ease-standard:   cubic-bezier(.2,0,0,1);
  --ease-emphasized: cubic-bezier(.3,0,0,1);

  /* ========== 小程序专属尺寸 ========== */
  --tabbar-height:    100rpx;  /* 50px */
  --navbar-height:    88rpx;   /* 44px */
  --statusbar-height: 88rpx;   /* 实际由 wx.getSystemInfoSync().statusBarHeight 提供 */

  /* ========== Page 默认 ========== */
  font-family: -apple-system, BlinkMacSystemFont,
               "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
               system-ui, sans-serif;
  font-size: var(--font-size-base);
  line-height: var(--leading-normal);
  color: var(--weui-fg-0);
  background: var(--weui-bg-1);
}

/* ============================================================
 * 暗黑模式（prefers-color-scheme: dark）
 * 需要在 app.json 中开启 "darkmode": true
 * ============================================================ */
@media (prefers-color-scheme: dark) {
  page {
    --color-neutral-50:  #111111;
    --color-neutral-100: #1a1a1a;
    --color-neutral-200: #2a2a2a;
    --color-neutral-300: #3d3d3d;
    --color-neutral-500: #888888;
    --color-neutral-700: #d6d6d6;
    --color-neutral-900: #fafafa;

    --weui-bg-0: #111111;
    --weui-bg-1: #1a1a1a;
    --weui-bg-2: #222222;
    --weui-fg-0: #ffffff;
    --weui-fg-1: rgba(255,255,255,.55);
    --weui-fg-2: rgba(255,255,255,.3);
    --weui-separator: rgba(255,255,255,.1);

    --shadow-sm: 0 2rpx 4rpx rgba(0,0,0,.2);
    --shadow-md: 0 4rpx 16rpx -4rpx rgba(0,0,0,.3);
    --shadow-lg: 0 16rpx 40rpx -8rpx rgba(0,0,0,.4);
  }
}

/* ============================================================
 * 通用 WeUI 组件样式
 * ============================================================ */

/* --- 按钮 --- */
.weui-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(100% - 64rpx);
  margin: 0 auto;
  height: 96rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--weight-medium);
  transition: opacity var(--dur-fast) var(--ease-standard);
  border: none;
}
.weui-btn:active { opacity: 0.7; }
.weui-btn--primary { background: var(--weui-brand); color: #fff; }
.weui-btn--default {
  background: var(--weui-bg-2);
  color: var(--weui-brand);
  border: 2rpx solid var(--weui-brand);
}
.weui-btn--warn { background: var(--weui-red); color: #fff; }
.weui-btn--disabled { opacity: 0.5; pointer-events: none; }

/* --- Cell 列表 --- */
.weui-cells {
  background: var(--weui-bg-2);
  margin-top: var(--space-2);
}
.weui-cell {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  min-height: 96rpx;
  border-bottom: 2rpx solid var(--weui-separator);
}
.weui-cell:last-child { border-bottom: none; }
.weui-cell__hd { margin-right: var(--space-3); }
.weui-cell__bd { flex: 1; font-size: var(--font-size-base); color: var(--weui-fg-0); }
.weui-cell__ft {
  color: var(--weui-fg-2);
  font-size: var(--font-size-sm);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* --- 表单 --- */
.weui-form-cell {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  background: var(--weui-bg-2);
  border-bottom: 2rpx solid var(--weui-separator);
}
.weui-form-label {
  width: 160rpx;
  font-size: var(--font-size-base);
  color: var(--weui-fg-0);
}
.weui-form-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--weui-fg-0);
  background: transparent;
}

/* --- 标签 --- */
.weui-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
}
.weui-tag--green  { background: rgba(7,193,96,.12);   color: var(--weui-brand); }
.weui-tag--orange { background: rgba(250,157,59,.12); color: var(--weui-orange); }
.weui-tag--red    { background: rgba(250,81,81,.12);  color: var(--weui-red); }
.weui-tag--blue   { background: rgba(16,174,255,.12); color: var(--weui-blue); }

/* --- 徽章 --- */
.weui-badge {
  display: inline-block;
  min-width: 16rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: var(--weui-red);
  color: #fff;
  font-size: var(--font-size-xs);
  line-height: 32rpx;
  text-align: center;
}

/* --- iPhone X+ 安全区 --- */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
.tabbar-wrap {
  height: calc(var(--tabbar-height) + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
}
